# Database
DB_HOST=localhost
DB_NAME=iwea
DB_USER=
DB_PASS=

# Weather API keys
OWM_API_KEY=
AERIS_CLIENT_ID=
AERIS_CLIENT_SECRET=
WWO_API_KEY=

# App config
APP_TIMEZONE=Europe/Kyiv
APP_DEFAULT_CITY=3   # DB id of the default city (see city table)
APP_DEFAULT_SITE=4   # DB id of the default weather source (4=OpenMeteo, free, no key needed)
APP_DOMAIN=https://yourdomain.com   # use https:// in production
APP_START_DATE=2016-05-12   # earliest date with weather data
